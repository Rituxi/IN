# ============================================
# 必需配置 - 必须设置才能正常运行
# ============================================

# Gemini API Key - 用于AI识别和智能小结
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Redis 配置 - 用于数据存储 (两种方式任选其一)
# 
# 方式一 (推荐): 使用 TCP 连接字符串 (支持 Upstash、阿里云、腾讯云等)
# Upstash 用户: 在控制台复制 "Connection string (TLS enabled)"
# 格式: rediss://default:密码@主机:端口
REDIS_URL="rediss://default:your_password@your-redis.upstash.io:6379"
#
# 方式二 (兜底): 使用 Upstash REST API
# 获取地址: https://upstash.com (免费套餐可用)
# UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your_redis_token_here"

# ============================================
# 可选配置 - 有默认值
# ============================================

# 管理员密码 - 访问 /admin 后台使用
# 默认值: admin123 (强烈建议修改!)
ADMIN_PASSWORD="admin123"

# 服务端口 (部署平台通常会自动设置)
# PORT=3000

# 运行环境 (部署平台自动设置)
# NODE_ENV=production
